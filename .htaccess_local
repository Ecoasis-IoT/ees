# =============================================================================
# EES — LOCAL DEVELOPMENT .htaccess
# For Apache 2.4 on Windows, site installed in a subdirectory:
#   http://localhost/ees/
#
# Usage: copy or rename this file to .htaccess on your local machine.
#        For production, use .htaccess_production.
# =============================================================================

Options -Indexes +FollowSymLinks

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /ees

    # Block access to sensitive files and directories
    RewriteRule ^\.env$                       - [F,L]
    RewriteRule ^\.htaccess_                  - [F,L]
    RewriteRule ^config\.php$                 - [F,L]
    RewriteRule ^core/logs/                   - [F,L]
    RewriteRule ^vendor/                      - [F,L]
    RewriteRule ^composer\.(json|lock)$       - [F,L]
    RewriteRule ^database/                    - [F,L]
</IfModule>

# Security headers (requires mod_headers — enable in httpd.conf)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Protect hidden files (.env, .htaccess, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block sensitive file extensions
<FilesMatch "\.(env|log|ini|sh|bat|sql|gz)$">
    Require all denied
</FilesMatch>

# Custom error pages
ErrorDocument 404 /ees/core/error-404.php
ErrorDocument 500 /ees/core/error-500.php
ErrorDocument 403 /ees/core/error-404.php

# PHP settings — development: show all errors
<IfModule mod_php.c>
    php_flag  display_errors         On
    php_flag  display_startup_errors On
    php_flag  log_errors             On
    php_value error_reporting        32767
    php_value upload_max_filesize    10M
    php_value post_max_size          12M
    php_value max_execution_time     60
</IfModule>

# No caching in development
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|jpg|jpeg|png|gif|ico|svg|webp|woff|woff2|ttf)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>
