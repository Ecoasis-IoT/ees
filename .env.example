# =====================================================
# SMTP Configuration
# =====================================================
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=EES Platform

# =====================================================
# Application Configuration
# =====================================================
TIMEZONE=Indian/Mauritius
BASE_URL=http://localhost/EES
SESSION_LIFETIME=14400

ENVIRONMENT=development
HTTPS_ENABLED=false
CSP_ENABLED=false
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000
DISPLAY_ERRORS=true

# =====================================================
# Security Settings
# =====================================================
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=1800
LOGIN_RATE_LIMIT=10
LOGIN_RATE_LIMIT_WINDOW=60
MAX_EMAIL_LENGTH=60
MAX_NAME_LENGTH=50
MIN_NAME_LENGTH=1
MAX_PASSWORD_LENGTH=255
MAX_PASSWORD_DISPLAY_LENGTH=30
MIN_PASSWORD_LENGTH=8
CAPTCHA_ENABLED=false
CAPTCHA_ATTEMPTS_THRESHOLD=3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
ADMIN_CAN_VIEW_ALL_PROFILES=true
ADMIN_USERGROUP_ID=1
REGISTRATION_LINK_ENABLED=false
REGISTRATION_LINK_SECRET=
REGISTRATION_LINK_EXPIRY=86400
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=upload
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
UPLOAD_USE_SECURE_NAMES=true
PASSWORD_HISTORY_COUNT=5
PASSWORD_EXPIRATION_DAYS=0

# =====================================================
# Session Cookie
# =====================================================
SESSION_COOKIE_LIFETIME=0
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Strict
SESSION_USE_STRICT_MODE=true

# =====================================================
# CDN Versions
# =====================================================
JQUERY_VERSION=3.7.1
JQUERY_SRI_HASH=sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==
SWEETALERT2_VERSION=11.11.0
SWEETALERT2_JS_SRI_HASH=
SWEETALERT2_CSS_SRI_HASH=
FONTAWESOME_VERSION=6.5.1
FONTAWESOME_SRI_HASH=
CDN_CDNJS_URL=https://cdnjs.cloudflare.com
CDN_JSDELIVR_URL=https://cdn.jsdelivr.net
CDN_GOOGLE_FONTS_URL=https://fonts.googleapis.com

# =====================================================
# Webhook / 2FA
# =====================================================
WEBHOOK_SECRET=
WEBHOOK_IP_WHITELIST=
WEBHOOK_REQUIRE_SIGNATURE=false
WEBHOOK_RATE_LIMIT_MAX=100
WEBHOOK_RATE_LIMIT_WINDOW=60
TWO_FACTOR_ENABLED=false
TWO_FACTOR_ISSUER=EES System
TWO_FACTOR_REQUIRED_FOR_ADMIN=false
TWO_FACTOR_BACKUP_CODES_COUNT=10
TWO_FACTOR_WINDOW=1
