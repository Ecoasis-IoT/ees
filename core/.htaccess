# =============================================================================
# core/.htaccess — EES core pages
#
# Rewrites extensionless URLs to their .php equivalent:
#   /ees/core/site-dashboard?site=1  →  site-dashboard.php   (local)
#   /core/site-dashboard?site=1      →  site-dashboard.php   (production)
#
# No RewriteBase needed — relative substitution resolves automatically
# against whatever directory this .htaccess lives in.
# =============================================================================

DirectoryIndex dashboard.php
Options +FollowSymLinks -Indexes -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Skip if the file or directory already exists
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # Rewrite extensionless request to its .php counterpart
    RewriteRule ^([^.]+)$ $1.php [NC,L,QSA]
</IfModule>
