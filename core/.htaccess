# =============================================================================
# core/.htaccess — EES core pages
#
# Rewrites extensionless URLs to .php for any path depth:
#   scripts/userlogin  →  scripts/userlogin.php
#   login              →  login.php
#
# The old single-segment rule ^([^.]+)$ broke paths like scripts/userlogin.
# =============================================================================

DirectoryIndex dashboard.php
Options +FollowSymLinks -Indexes -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L,QSA]
</IfModule>
