# =============================================================================
# EES — PRODUCTION .htaccess (aligned with CRM + REQUEST_URI strip for LiteSpeed)
# Upload as .htaccess. BASE_URL in .env must match the public site URL.
#
# CRM: Options, RewriteEngine at top; strip .php; bare paths -> core/;
# EES: exclude callback/, cron/, database/, gateway/, vendor/ from core/ routing.
# =============================================================================

Options +FollowSymLinks -MultiViews -Indexes
RewriteEngine On
RewriteBase /

# HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Block access to sensitive files and directories
RewriteRule ^\.env$                       - [F,L]
RewriteRule ^\.htaccess_                  - [F,L]
RewriteRule ^config\.php$                 - [F,L]
RewriteRule ^config$                      - [F,L]
RewriteRule ^core/logs/                   - [F,L]
RewriteRule ^vendor/                      - [F,L]
RewriteRule ^composer\.(json|lock)$       - [F,L]
RewriteRule ^database/                    - [F,L]

# --- Extensionless URLs (same idea as CRM) ---
# CRM uses THE_REQUEST; we also strip via REQUEST_URI so LiteSpeed/proxies still canonicalize.

# /index.php -> /
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{REQUEST_URI} ^/index\.php$ [NC]
RewriteRule ^ / [R=302,L,QSA]

# External redirect: /any/path.php -> /any/path (skip integration dirs)
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=302,L,NE,QSA]

RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{REQUEST_URI} ^/(.+)\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/(callback|cron|database|gateway|vendor)(/|$) [NC]
RewriteRule ^ /%1 [R=302,L,QSA]

# Route bare URLs to core/ (CRM: core/$1) — not for API roots above
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(core|callback|cron|database|gateway|vendor)(/|$) [NC]
RewriteRule ^(.*)$ core/$1 [L]

# Internal: /dir/foo -> /dir/foo.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

DirectoryIndex index.php

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Protect hidden files (.env, .htaccess, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Security: sensitive names and extensions (CRM-style + common env variants)
<FilesMatch "^(\.env|\.env\.prod|\.env\.example|config\.php)$">
    Require all denied
</FilesMatch>
<FilesMatch "\.(env|log|ini|sh|bat|sql|gz)$">
    Require all denied
</FilesMatch>

# PHP — production
<IfModule mod_php.c>
    php_flag display_errors         Off
    php_flag log_errors             On
    php_value error_reporting       E_ALL
    php_value error_log             logs/php_errors.log
    php_value upload_max_filesize   10M
    php_value post_max_size         12M
    php_value max_execution_time    60
</IfModule>

# Static asset caching
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=86400, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|svg|webp)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Custom error pages
ErrorDocument 404 /core/error-404.php
ErrorDocument 500 /core/error-500.php
ErrorDocument 403 /core/error-404.php
